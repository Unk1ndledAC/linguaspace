ENVIRONMENT=local
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

POSTGRES_DB=linguaspace
POSTGRES_USER=linguaspace
POSTGRES_PASSWORD=linguaspace
POSTGRES_URL=postgresql+psycopg://linguaspace:linguaspace@localhost:5432/linguaspace

MYSQL_DATABASE=linguaspace
MYSQL_USER=linguaspace
MYSQL_PASSWORD=linguaspace
MYSQL_ROOT_PASSWORD=linguaspace-root
MYSQL_URL=mysql+pymysql://linguaspace:linguaspace@localhost:3306/linguaspace
DATA_BACKEND=mysql

REDIS_URL=redis://localhost:6379/0

MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=linguaspace
MINIO_SECRET_KEY=linguaspace
MINIO_SECURE=false

NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=linguaspace

LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen3.5:0.8b
OLLAMA_FALLBACK_MODEL=qwen2.5:1.5b
OLLAMA_VISION_MODEL=qwen3-vl:4b

OPENAI_COMPATIBLE_BASE_URL=
OPENAI_COMPATIBLE_API_KEY=
OPENAI_COMPATIBLE_MODEL=
