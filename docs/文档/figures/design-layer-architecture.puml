@startuml
skinparam dpi 160
skinparam shadowing false
skinparam packageStyle rectangle
skinparam rectangle {
  BackgroundColor #F8FAFC
  BorderColor #334155
}
title 系统设计五层架构图

rectangle "客户端层\n游客端 / 学生端 / 导游端 / 管理端" as Client
rectangle "接口与网关层\nHTTP API / 鉴权 / 限流 / 参数校验" as Gateway
rectangle "业务服务层\n导览服务 / 实训服务 / 协同服务 / 审核服务 / 日志服务" as Business
rectangle "AI 编排层\nASR / 翻译 / 视觉 / 向量化 / LLM / TTS 适配器" as AI
rectangle "知识增强层\nRAG 知识库 / 术语表 / 文化图谱 / 来源追踪" as Knowledge
rectangle "数据与运维层\nPostgreSQL / Milvus / Neo4j / Redis / MinIO / 监控日志" as Data

Client --> Gateway : 提交请求
Gateway --> Business : 路由到业务服务
Business --> AI : 调用模型能力
Business --> Knowledge : 检索可信上下文
AI --> Knowledge : 向量化与生成增强
Knowledge --> Data : 读取知识、图谱、向量
Business --> Data : 持久化会话、训练、审核、日志
Data --> Business : 返回数据与状态
Business --> Gateway : 统一响应
Gateway --> Client : 展示结果
@enduml
