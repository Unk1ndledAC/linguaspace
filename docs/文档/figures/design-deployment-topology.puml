@startuml
skinparam dpi 160
skinparam shadowing false
title LinguaSpace MVP 部署拓扑

node "用户浏览器" as Browser
node "本机应用进程" {
  component "Vite React Web\n5173-5190" as Web
  component "FastAPI\n8000" as API
  component "Ollama\n11434" as Ollama
  component "faster-whisper\n按配置启用" as ASR
  component "Windows SAPI" as TTS
}
node "Docker Compose 基础设施" {
  database "MySQL 8.4\n3307\n运行时主库" as MySQL
  database "PostgreSQL/pgvector\n5432\n后续增强预留" as PG
  database "Redis\n6379\n缓存" as Redis
  cloud "MinIO\n9000\n对象存储" as MinIO
  database "Neo4j\n7687\n图谱镜像" as Neo4j
}

Browser --> Web : HTTP
Web --> API : REST API
API --> MySQL
API --> Redis
API --> MinIO
API --> Neo4j
API ..> PG : 健康检查 / 预留
API --> Ollama : 文本与视觉模型
API --> ASR
API --> TTS
@enduml
