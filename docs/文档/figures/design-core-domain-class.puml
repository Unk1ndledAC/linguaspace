@startuml
skinparam dpi 160
skinparam shadowing false
skinparam classAttributeIconSize 0
title LinguaSpace 核心领域类图

class User {
  id
  username
  role
  language
  status
}
class GuideSession {
  id
  visitorName
  language
  location
  status
  riskLevel
}
class Message {
  id
  sessionId
  role
  inputType
  question
  answer
  reliable
}
class VisitorProfile {
  sessionId
  interests
  intentTypes
  visitStatus
  riskLevel
}
class Favorite {
  id
  sessionId
  itemType
  itemId
  title
}
class TakeoverLog {
  id
  sessionId
  action
  guideId
  note
}
class KnowledgeDocument {
  id
  title
  source
  content
  status
  vectorStatus
}
class KnowledgeChunk {
  id
  documentId
  title
  content
  status
  vectorStatus
}
class ReviewTask {
  id
  objectType
  objectId
  status
  reviewer
}
class TrainingRecord {
  id
  scenario
  question
  answer
  score
  metrics
}
class GuideCorrection {
  id
  recordId
  mode
  optimizedAnswer
  status
}
class ModelCallLog {
  id
  requestId
  capability
  provider
  model
  latencyMs
}
class RequestTrace {
  id
  sessionId
  question
  language
  pipeline
}

GuideSession "1" *-- "*" Message
GuideSession "1" o-- "0..1" VisitorProfile
GuideSession "1" o-- "*" Favorite
GuideSession "1" o-- "*" TakeoverLog
KnowledgeDocument "1" *-- "*" KnowledgeChunk
KnowledgeChunk "1" o-- "*" ReviewTask
GuideCorrection "1" o-- "*" ReviewTask
TrainingRecord "1" o-- "*" GuideCorrection
GuideSession "1" o-- "*" RequestTrace
Message ..> ModelCallLog : 触发模型调用
User ..> GuideSession : 角色访问
@enduml
